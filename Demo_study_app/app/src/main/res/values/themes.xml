<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- App Theme -->
    <style name="Theme.Demo_Study_App" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/blue_color</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Text Color -->
        <item name="android:textColor">@color/black</item>
    </style>

    <!-- Custom Radio Button Style -->
    <style name="CustomRadioButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:padding">14dp</item>
        <item name="android:buttonTint">@color/primaryBlue</item>
    </style>

    <!-- Bottom Navigation Style -->
    <style name="BottomNavigationStyle" parent="Widget.Design.BottomNavigationView">
        <item name="android:elevation">8dp</item>
        <item name="itemTextAppearanceActive">@style/BottomNavigationTextActive</item>
        <item name="itemTextAppearanceInactive">@style/BottomNavigationTextInactive</item>
    </style>

    <!-- Bottom Navigation Text Styles -->
    <style name="BottomNavigationTextActive">
        <item name="android:textSize">14sp</item>
    </style>

    <style name="BottomNavigationTextInactive">
        <item name="android:textSize">10sp</item>
    </style>

    <!-- Toolbar Title Styles -->
    <style name="ExpandedTitleStyle" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textSize">1sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="background">@color/black</item>
    </style>

    <style name="CollapsedTitleStyle" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textSize">17sp</item>
    </style>

</resources>
