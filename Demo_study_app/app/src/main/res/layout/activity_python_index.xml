<!--            android:textColor="@color/primaryBlue"-->
<!--            android:layout_marginStart="8dp"-->
<!--            android:fontFamily="@font/poppins_regular" />-->
<!--    </LinearLayout>-->

    <!-- Course Details -->
    <TextView
        android:id="@+id/tvCourseDetails"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="14dp"
        android:text="📚 10 Modules | 🧠 10 Quizzes | 🏆 Master Quiz"
        android:textColor="@color/black"
        android:fontFamily="@font/poppins_medium"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvIndexTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- RecyclerView for Index (Expandable) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/indexRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="18dp"
        android:paddingHorizontal="4dp"
        android:padding="5dp"
        android:backgroundTint="@color/light_grey"
        android:clipToPadding="false"
        android:background="@drawable/rounded_background2"
        android:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvCourseDetails"
        app:layout_constraintBottom_toTopOf="@id/startNowButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Start Now Button -->
    <Button
        android:id="@+id/startNowButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="7dp"
        android:layout_marginHorizontal="30dp"
        android:backgroundTint="@color/primaryBlue"
        android:gravity="center"
        android:fontFamily="@font/poppins_medium"
        android:background="@drawable/rounded_corner"
        android:text="START YOUR JOURNEY NOW!"
        android:textAllCaps="true"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:paddingVertical="7dp"
        android:foreground="?attr/selectableItemBackground"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/indexRecyclerView" />
</androidx.constraintlayout.widget.ConstraintLayout>